# Supabase (Postgres + Storage)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Session signing (any 32+ char random string)
SESSION_SECRET=change-me-to-a-long-random-string

# Email provider (leave blank in dev — mock provider is used)
EMAIL_PROVIDER=mock            # mock | sendgrid | ses
SES_REGION=
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
SENDGRID_API_KEY=              # Twilio SendGrid API key with "Mail Send" scope
EMAIL_FROM_ADDRESS=hello@18startup.in    # must be a verified sender in SendGrid
EMAIL_FROM_NAME=18startup

# WhatsApp Business API (via a BSP)
WHATSAPP_PROVIDER=mock         # mock | twilio | gupshup | interakt | aisensy | wati
WHATSAPP_API_KEY=
WHATSAPP_SENDER_NUMBER=
WHATSAPP_WEBHOOK_SECRET=

# Twilio WhatsApp (used when WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=          # e.g. whatsapp:+14155238886

# Telephony (India — Exotel-first)
TELEPHONY_PROVIDER=mock        # mock | exotel | knowlarity | myoperator | ozonetel
TELEPHONY_ACCOUNT_SID=
TELEPHONY_API_KEY=
TELEPHONY_API_TOKEN=
TELEPHONY_CALLER_ID=
TELEPHONY_WEBHOOK_SECRET=
